# .env.example
# Copy this file to .env and replace the placeholder values with your real
# secrets and RPC endpoints. Never commit your real .env (keep it private).

# -------------------------------
# Required (for deploy, update, mint)
# -------------------------------

# Sepolia RPC URL (Alchemy, Infura or other provider). Example:
# https://eth-sepolia.g.alchemy.com/v2/your-api-key
SEPOLIA_RPC_URL="https://eth-sepolia.alchemyapi.io/v2/your-api-key"

# Deployer private key used by the foundry scripts and `manage.sh` broadcast
# Format: 0x<hex> (KEEP THIS SECRET). You can also use an environment
# manager/service account instead of storing locally.
PRIVATE_KEY="yourprivatekeyhere"

# Deployed Token42NFT contract address (used by mint scripts / web UI)
CONTRACT_ADDRESS="0xFcE8134d569F41Fb05b52A081B9197840148caaf"

# -------------------------------
# Optional / Helpful
# -------------------------------

# Mainnet RPC URL (if you also interact with mainnet via foundry)
MAINNET_RPC_URL="https://mainnet.infura.io/v3/your-api-key"

# Etherscan API key used for verification (foundry/etherscan integration)
ETHERSCAN_API_KEY="your-etherscan-api-key"

# IPFS hash for the `SVGs/beautiful` folder (used in README / UpdateIPFS script)
IPFS_HASH="bafybeifuat6mqtsgaotpz2cdw6botsxdgggaicflcrqxgentiic5kec6ze"

PINATA_API_KEY=6cd00e41815edbba8e99
PINATA_SECRET_KEY=abc

# -------------------------------
# Notes
# -------------------------------
# - Copy this file to `.env` and fill in real values before running
#   `./manage.sh deploy`, `./manage.sh update`, or `./manage.sh mint`.
# - This project loads the dotenv file from the `code` project via
#   `code/foundry.toml` (dotenv = "../.env").
# - Keep your private keys out of version control. Use a secrets manager for
#   production. Remove PRIVATE_KEY from `.env` when sharing.