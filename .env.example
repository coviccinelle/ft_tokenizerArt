# Rename this file to .env and fill in your details
# Private key for deployment (without 0x prefix for vm.envUint)
PRIVATE_KEY=0000

# RPC endpoints - you can use public ones or your own
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
MAINNET_RPC_URL=https://ethereum-rpc.publicnode.com

# Active RPC for scripts (change this to switch networks)
RPC=https://ethereum-sepolia-rpc.publicnode.com

# Contract address (set this after deployment)
CONTRACT_ADDRESS=0x000

# Recipient address for minting (your wallet address)
RECIPIENT_ADDRESS=0x0000

# Etherscan API key for contract verification (optional)
ETHERSCAN_API_KEY=000

# IPFS configuration
# IPFS_URL=https://ipfs.infura.io:5001
# IPFS_PROJECT_ID=your_ipfs_project_id
# IPFS_PROJECT_SECRET=your_ipfs_project_secret

# public key = 0x000
